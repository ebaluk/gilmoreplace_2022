# Server deploy env (copy to prod_server.env on the host and set secrets).
# Used by docker-compose.yaml on DEV/prod behind nginx-proxy.
#
# Canonical app secrets for Ansible / GitHub Actions deploy — not .env.production.
# rsync excludes this file; Actions does not write it (only DEV_SSH_PRIVATE_KEY for SSH).
# Edit on the server (or scp); bootstrap from this example if missing.

# --- nginx-proxy (SSL on host) ---
VIRTUAL_HOST=gilmoreplace.ebaluk.store
VIRTUAL_PORT=80
LETSENCRYPT_HOST=gilmoreplace.ebaluk.store
LETSENCRYPT_EMAIL=ebaluk@gmail.com

# --- Django ---
DJANGO_SETTINGS_MODULE=gilmoreplace_2022.settings.production
SECRET_KEY=change-me
ALLOWED_HOSTS=gilmoreplace.ebaluk.store,localhost,backend,backend:8000
DEBUG=0
CSRF_TRUSTED_ORIGINS=https://gilmoreplace.ebaluk.store

# --- Database ---
DB_NAME=gilmoreplace_2022
DB_USER=django
DB_PASSWORD=change-me
DB_HOST=postgres
DB_PORT=5432

POSTGRES_DB=gilmoreplace_2022
POSTGRES_USER=django
POSTGRES_PASSWORD=change-me

# --- Next.js / CORS (public HTTPS URL for browser) ---
WAGTAIL_API_URL=http://backend:8000/api/v2
NEXT_PUBLIC_API_URL=https://gilmoreplace.ebaluk.store
CORS_ORIGINS=https://gilmoreplace.ebaluk.store

# --- Revalidation ---
REVALIDATION_SECRET=change-me
PREVIEW_SECRET=change-me
NEXTJS_BASE_URL=http://frontend:3000
NEXTJS_PUBLIC_URL=https://gilmoreplace.ebaluk.store

# Optional API keys (override settings/base.py defaults)
# GOOGLE_MAP_API_KEY=
# RECAPTCHA_SITEKEY=
# RECAPTCHA_SECRET=
