# Local / reference only — used by deploy/compose/prod.yml
#
# NOT used by server deploy (docker-compose.yaml) or GitHub Actions.
# For DEV/prod on the server, copy prod_server.env.example → prod_server.env
# and keep secrets on the host. Do not commit this file or store it as a
# GitHub Actions secret; Actions only needs DEV_SSH_PRIVATE_KEY for SSH.

# Django production (Docker Compose)
DJANGO_SETTINGS_MODULE=gilmoreplace_2022.settings.production
SECRET_KEY=change-me-to-a-random-50-char-string
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# PostgreSQL on host
DB_NAME=gilmoreplace_2022
DB_USER=django
DB_PASSWORD=change-me
DB_HOST=host.docker.internal
DB_PORT=5432

# Postgres container (if using docker-compose.yml)
POSTGRES_DB=gilmoreplace_2022
POSTGRES_USER=django
POSTGRES_PASSWORD=change-me

# Next.js
NEXT_PUBLIC_API_URL=http://backend:8000
WAGTAIL_API_URL=http://backend:8000/api/v2

# CORS (comma-separated)
CORS_ORIGINS=https://yourdomain.com

# Revalidation webhook
REVALIDATION_SECRET=change-me-to-a-random-string
PREVIEW_SECRET=change-me-to-a-random-string
NEXTJS_BASE_URL=http://frontend:3000
NEXTJS_PUBLIC_URL=https://gilmoreplace.ebaluk.store

# API keys (override hardcoded defaults from settings/base.py)
# GOOGLE_MAP_API_KEY=
# RECAPTCHA_SITEKEY=
# RECAPTCHA_SECRET=
# SOC_TW_CONSUMER_KEY=
# SOC_TW_CONSUMER_SECRET=
# SOC_TW_USER_TOKEN=
# SOC_TW_USER_SECRET=
# SOC_IN_ACCESS_TOKEN=
# SOC_FB_APP_ID=
# SOC_FB_APP_SECRET=

# Optional: Redis cache
# REDIS_URL=redis://redis:6379/0
