# Django local dev settings (runs directly on host)
DJANGO_SETTINGS_MODULE=gilmoreplace_2022.settings.dev
SECRET_KEY=local-dev-secret-key-change-me

# Database (optional — defaults to local.py settings, SQLite or local Postgres)
# DB_NAME=gilmoreplace_2022
# DB_USER=django
# DB_PASSWORD=123
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Next.js API URL (Django runs on localhost:8000)
WAGTAIL_API_URL=http://localhost:8000/api/v2
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS
CORS_ORIGINS=http://localhost:3000

# Revalidation / headless preview
REVALIDATION_SECRET=dev-secret
PREVIEW_SECRET=dev-secret
NEXTJS_BASE_URL=http://localhost:3000
NEXTJS_PUBLIC_URL=http://localhost:3000

# API keys (from settings/base.py defaults)
# GOOGLE_MAP_API_KEY=
# RECAPTCHA_SITEKEY=
# RECAPTCHA_SECRET=
